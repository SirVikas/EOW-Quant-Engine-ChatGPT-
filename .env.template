# ── EOW Quant Engine — Environment Variables ──────────────────────────────────
# Copy this file to .env and fill in your credentials.

# Binance API (leave blank for paper trading without real data)
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here
BINANCE_TESTNET=false

# Redis (default local)
REDIS_URL=redis://localhost:6379/0

# TimescaleDB (optional — engine works without it using in-memory store)
DB_URL=postgresql+asyncpg://quant:quant@localhost:5432/eow_quant

# Trading Mode: PAPER | LIVE
TRADE_MODE=PAPER

# API control-plane security
# Set to false only for local development in PAPER mode.
AUTH_ENABLED=true
# Comma-separated origins allowed by CORS:
ALLOWED_ORIGINS=http://localhost:8000
# Comma-separated token:role pairs (roles: operator, admin)
CONTROL_API_KEYS=replace_operator_token:operator,replace_admin_token:admin

# Starting capital (USDT)
INITIAL_CAPITAL=1000.0
